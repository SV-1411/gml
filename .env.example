# GML Infrastructure - Environment Configuration
# Local development settings optimized for MacBook Pro M4
# Change marked values for production deployments

# ============================================================================
# APPLICATION CORE SETTINGS
# ============================================================================

# Application name and environment identifier
APP_NAME=gml-infrastructure
APP_ENV=development
APP_DEBUG=true

# Server host and port
APP_HOST=0.0.0.0
APP_PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Environment type (development, staging, production)
ENVIRONMENT=development

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Database URL (Docker Compose: postgresql://postgres:postgres@postgres:5432/gml_db)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gml_db

# Supabase Cloud Database (optional - use for cloud deployments)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Database pool settings
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_TIMEOUT=30

# ============================================================================
# REDIS CACHE CONFIGURATION
# ============================================================================

# Redis connection URL or individual components
# URL Format: redis://:password@host:port/db
REDIS_URL=redis://localhost:6379/0

# Redis host and port (alternative to REDIS_URL)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false

# Redis connection pool settings
REDIS_POOL_MIN=2
REDIS_POOL_MAX=10

# ============================================================================
# VECTOR DATABASE - QDRANT CONFIGURATION
# ============================================================================

# Qdrant API endpoint (HTTP) for vector operations
QDRANT_URL=http://localhost:6333

# Qdrant gRPC endpoint for high-performance queries
QDRANT_GRPC_URL=localhost:6334

# Default collection name for embeddings
QDRANT_COLLECTION_NAME=embeddings

# Vector embedding size (depends on embedding model)
QDRANT_VECTOR_SIZE=1536

# Search threshold for similarity (0.0 to 1.0, higher = stricter)
QDRANT_SEARCH_THRESHOLD=0.7

# ============================================================================
# S3 STORAGE - MINIO CONFIGURATION
# ============================================================================

# MinIO API endpoint
MINIO_URL=http://localhost:9000

# MinIO console URL (web UI)
MINIO_CONSOLE_URL=http://localhost:9001

# MinIO root credentials (Docker Compose defaults)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MinIO buckets
MINIO_BUCKET_UPLOADS=uploads
MINIO_BUCKET_BACKUPS=backups
MINIO_BUCKET_MODELS=models

# MinIO region
MINIO_REGION=us-east-1

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# Secret key for session encryption (generate: openssl rand -hex 32)
# CHANGE THIS IN PRODUCTION!
SECRET_KEY=dev-secret-key-change-in-production-with-openssl-rand-hex-32

# JWT (JSON Web Token) settings
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Legacy JWT configuration (minutes, for backwards compatibility)
JWT_EXPIRATION_MINUTES=1440

# Password hashing algorithm
PASSWORD_ALGORITHM=bcrypt

# Password requirements
MIN_PASSWORD_LENGTH=8
REQUIRE_SPECIAL_CHARS=true
REQUIRE_UPPERCASE=true
REQUIRE_DIGITS=true

# ============================================================================
# AI/ML MODEL CONFIGURATION
# ============================================================================

# OpenAI API key (https://platform.openai.com/api-keys)
# KEEP THIS SECRET - DO NOT COMMIT!
OPENAI_API_KEY=sk-your-openai-api-key-here

# Embedding model for vectorization
EMBEDDING_MODEL=text-embedding-3-small

# Embedding model dimension (depends on chosen model)
# text-embedding-3-small: 1536
# text-embedding-3-large: 3072
EMBEDDING_DIMENSION=1536

# LLM model for text generation
LLM_MODEL=gpt-4-turbo-preview

# Model timeout in seconds
MODEL_TIMEOUT=60

# Maximum tokens for model responses
MAX_TOKENS=2048

# Model temperature (0.0 to 2.0, lower = more deterministic)
MODEL_TEMPERATURE=0.7

# ============================================================================
# MESSAGE QUEUE - RABBITMQ CONFIGURATION
# ============================================================================

# RabbitMQ connection settings
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Celery broker and result backend
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Celery task settings
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================

# Prometheus metrics port
PROMETHEUS_PORT=9090

# Enable/disable monitoring features
METRICS_ENABLED=true
TRACING_ENABLED=true

# OpenTelemetry configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=gml-infrastructure

# ============================================================================
# RATE LIMITING
# ============================================================================

# Rate limits per minute and hour
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# WORKER & TASK CONFIGURATION
# ============================================================================

# Maximum number of worker threads
MAX_WORKERS=4

# Worker timeout in seconds
WORKER_TIMEOUT=300

# Task queue size
TASK_QUEUE_SIZE=1000

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================

# Maximum number of concurrent agents
MAX_AGENTS=100

# Agent heartbeat interval in seconds
AGENT_HEARTBEAT_INTERVAL=30

# Agent timeout in seconds
AGENT_TIMEOUT=300

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API version prefix
API_V1_PREFIX=/api/v1

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Allow credentials in CORS requests
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Auto-reload on code changes
RELOAD=true

# Request body size limit (bytes)
MAX_BODY_SIZE=104857600

# Request timeout in seconds
REQUEST_TIMEOUT=30
