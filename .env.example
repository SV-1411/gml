# GML Infrastructure - Environment Configuration
# Simplified for Vercel + Render + Supabase + Pinecone
# Change marked values for production

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

APP_NAME=gml-infrastructure
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================================================
# SUPABASE DATABASE (PRIMARY)
# ============================================================================

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Direct Postgres (for Alembic migrations only)
DATABASE_URL=postgresql://postgres.your-project-id:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# ============================================================================
# PINECONE VECTOR DATABASE
# ============================================================================

PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=gml-memories

# ============================================================================
# REDIS CACHE (OPTIONAL - leave empty to disable)
# ============================================================================

REDIS_URL=

# ============================================================================
# SECURITY
# ============================================================================

SECRET_KEY=change-this-with-openssl-rand-hex-32-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# AI/ML
# ============================================================================

OPENAI_API_KEY=sk-your-openai-api-key-here
EMBEDDING_MODEL=text-embedding-3-small
LLM_PROVIDER=openai
